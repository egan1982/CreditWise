# config/users.yaml.example
# 内网测试用户配置模板
# 使用方式：
#   1. 复制本文件为 users.yaml:  copy users.yaml.example users.yaml
#   2. 用 scripts/hash_password.py 生成密码哈希
#   3. 替换下方 PLACEHOLDER 为真实哈希值

users:
  - username: admin
    password_hash: "$2b$12$PLACEHOLDER_USE_hash_password_py"
    role: admin
    org: ""
    description: "管理员"
    valid_until: ""              # 留空 = 永久有效（admin 建议留空）

  - username: user1
    password_hash: "$2b$12$PLACEHOLDER_USE_hash_password_py"
    role: user
    org: "部门名称"
    description: "测试用户1，有效期至年底"
    valid_until: "2026-12-31"   # 到期日期 YYYY-MM-DD，留空=永久有效

# 安全配置
settings:
  max_login_failures: 5          # 连续失败次数限制
  lockout_duration_minutes: 15   # 锁定时间（分钟）
