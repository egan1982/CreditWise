# Docker 构建时忽略的文件
# 这些文件不会被复制到镜像中

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
venv/
env/
ENV/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# 临时文件
*.log
*.tmp
.DS_Store

# 大文件
*.tar
*.tar.gz
*.zip
*.safetensors
*.bin

# 模型文件（通常很大，运行时再挂载）
models/
checkpoints/

# 非核心子项目（训练框架/实验代码，不参与生产部署）
# SkyRL: 强化学习训练框架（含 pickle.loads RCE 漏洞）
# ms-swift: 模型微调框架（含 torch.load/shell注入漏洞）
# playground: 数据集基准测试实验
deepanalyze/SkyRL/
deepanalyze/ms-swift/
playground/

# Node.js 依赖（由 Docker 内重新 npm install，避免 Windows/Linux 跨平台问题）
**/node_modules/

