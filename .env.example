# ==============================================================================
# DeepAnalyze 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM Manager 加密密钥（必需）
# 用于加密存储在数据库中的 API 密钥
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ------------------------------------------------------------------------------
LLM_MANAGER_ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# API 服务配置（可选，有默认值）
# ------------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8200
# CORS_ORIGINS=*
# LOG_LEVEL=INFO
# MAX_UPLOAD_SIZE_MB=500

# ------------------------------------------------------------------------------
# 认证模式（可选）
# true = 内网多用户模式（需配置 config/users.yaml）
# false = 单用户模式（无需登录）
# ------------------------------------------------------------------------------
ENABLE_AUTH=true

# ------------------------------------------------------------------------------
# LLM 配置（可选）
# 如果不通过 LLM Manager 管理密钥，可在此直接配置
# ------------------------------------------------------------------------------
# OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# LLM_API_BASE=http://localhost:8200/v1
# LLM_MODEL=deepseek-chat

# ------------------------------------------------------------------------------
# 任务管理器数据库（可选，默认 SQLite）
# ------------------------------------------------------------------------------
# TASK_MANAGER_DB_URL=sqlite:///./task_manager.db

# ------------------------------------------------------------------------------
# 开发模式（可选）
# 设为 true 时禁用 8200/llm-manager 静态页面，使用 Vite 开发服务器
# ------------------------------------------------------------------------------
# DEV_MODE=false
